<section class="page-header">
    <div>
        <p class="eyebrow">Connection</p>
        <h1>Add Relationship</h1>
        <p>Connect two people already in your tree.</p>
    </div>
</section>

<% if (typeof errors !=='undefined' && errors.length> 0) { %>
    <div class="alert alert-error">
        <strong>Please fix the following errors:</strong>
        <ul>
            <% errors.forEach(error=> { %>
                <li>
                    <%= error %>
                </li>
                <% }); %>
        </ul>
    </div>
    <% } %>

        <% if (members.length < 2) { %>
            <div class="alert alert-warning">
                You need at least 2 family members to create a relationship. <a href="/members/add">Add a member
                    first</a>.
            </div>
            <% } else { %>
                <form method="POST" class="form">
                    <div class="form-group">
                        <label for="member_id_1">This person *</label>
                        <select id="member_id_1" name="member_id_1" required>
                            <option value="">-- Select a member --</option>
                            <% members.forEach(member=> { %>
                                <option value="<%= member.id %>" <% if (data.member_id_1==member.id) { %>selected<% } %>
                                        >
                                        <%= member.first_name %>
                                            <%= member.last_name %>
                                </option>
                                <% }); %>
                        </select>
                    </div>

                    <div class="form-group">
                        <label for="relationship_type">Is this relationship *</label>
                        <select id="relationship_type" name="relationship_type" required>
                            <option value="">-- Select a relationship --</option>
                            <% relationshipTypes.forEach(type=> { %>
                                <option value="<%= type.value %>" <% if (data.relationship_type==type.value) { %>selected<% } %>>
                                    <%= type.label %>
                                </option>
                            <% }); %>
                        </select>
                    </div>

                    <div class="form-group">
                        <label for="member_id_2">Of this person *</label>
                        <select id="member_id_2" name="member_id_2" required>
                            <option value="">-- Select a member --</option>
                            <% members.forEach(member=> { %>
                                <option value="<%= member.id %>" <% if (data.member_id_2==member.id) { %>selected<% } %>
                                        >
                                        <%= member.first_name %>
                                            <%= member.last_name %>
                                </option>
                                <% }); %>
                        </select>
                    </div>

                    <div class="form-actions">
                        <button type="submit" class="btn btn-primary">Add Relationship</button>
                        <a href="/members" class="btn btn-secondary">Cancel</a>
                    </div>
                </form>
                <% } %>
