<div class="detail-header">
    <div>
        <p class="eyebrow">Profile</p>
        <h1>
            <%= member.first_name %>
                <%= member.last_name %>
                <% if (currentUser.self_member_id==member.id) { %>
                    <span class="badge">Me</span>
                <% } %>
        </h1>
    </div>
    <div class="detail-actions">
        <a href="/members/<%= member.id %>/edit" class="btn btn-warning">Edit</a>
        <% if (currentUser.self_member_id!=member.id) { %>
            <form method="POST" action="/members/<%= member.id %>/delete" style="display:inline;"
                onsubmit="return confirm('Are you sure you want to delete this member?');">
                <button type="submit" class="btn btn-danger">Delete</button>
            </form>
        <% } %>
        <a href="/members" class="btn btn-secondary">Back</a>
    </div>
</div>

<div class="detail-info">
    <div class="info-card">
        <h3>Personal Information</h3>
        <p><strong>Date of Birth:</strong>
            <%= member.date_of_birth || 'Not provided' %>
        </p>
        <p><strong>Gender:</strong>
            <%= member.gender === 'female' ? 'Female' : member.gender === 'male' ? 'Male' : member.gender === 'nonbinary' ? 'Non-binary' : 'Not provided' %>
        </p>
        <p><strong>Location of Birth:</strong>
            <%= member.location_of_birth || 'Not provided' %>
        </p>
        <p><strong>Current Location:</strong>
            <%= member.current_location || 'Not provided' %>
        </p>
        <p><strong>Member ID:</strong>
            <%= member.id %>
        </p>
    </div>

    <div class="info-card">
        <h3>Relationships</h3>
        <% if (relationships && relationships.length> 0) { %>
            <table class="relationships-table">
                <thead>
                    <tr>
                    <th>Relationship</th>
                        <th>Related Member</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    <% relationships.forEach(rel=> { %>
                        <tr>
                            <td><strong>
                                    <%= rel.display_label %>
                                </strong></td>
                            <td><a href="/members/<%= rel.related_member_id %>">
                                    <%= rel.related_first_name %>
                                        <%= rel.related_last_name %>
                                </a></td>
                            <td>
                                <form method="POST" action="/relationships/<%= rel.id %>/delete" style="display:inline;"
                                    onsubmit="return confirm('Remove this relationship?');">
                                    <input type="hidden" name="referrer" value="/members/<%= member.id %>">
                                    <button type="submit" class="btn btn-small btn-danger">Remove</button>
                                </form>
                            </td>
                        </tr>
                        <% }); %>
                </tbody>
            </table>
            <% } else { %>
                <p class="empty-message">No relationships added yet.</p>
                <% } %>
                    <a href="/relationships/add" class="btn btn-primary btn-small" style="margin-top: 10px;">Add Relationship</a>
    </div>
</div>
