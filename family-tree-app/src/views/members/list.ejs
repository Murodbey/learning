<section class="page-header">
    <div>
        <p class="eyebrow">Directory</p>
        <h1>Family Members</h1>
        <p>Manage the people connected to your tree.</p>
    </div>
    <a href="/members/add" class="btn btn-primary">Add Relative</a>
</section>

<% if (members && members.length> 0) { %>
    <table class="members-table">
        <thead>
            <tr>
                <th>Name</th>
                <th>Date of Birth</th>
                <th>Current Location</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            <% members.forEach(member=> { %>
                <tr>
                    <td>
                        <strong>
                            <%= member.first_name %>
                                <%= member.last_name %>
                        </strong>
                        <% if (currentUser.self_member_id==member.id) { %>
                            <span class="badge">Me</span>
                        <% } %>
                    </td>
                    <td>
                        <%= member.date_of_birth || '-' %>
                    </td>
                    <td>
                        <%= member.current_location || '-' %>
                    </td>
                    <td class="actions">
                        <a href="/members/<%= member.id %>" class="btn btn-small btn-info">View</a>
                        <a href="/members/<%= member.id %>/edit" class="btn btn-small btn-warning">Edit</a>
                    </td>
                </tr>
                <% }); %>
        </tbody>
    </table>
    <% } else { %>
        <section class="empty-page compact">
            <h1>Your profile is ready</h1>
            <p>Add your first relative to begin growing the tree.</p>
            <a href="/members/add" class="btn btn-primary">Add Relative</a>
        </section>
        <% } %>
