<section class="page-header">
    <div>
        <p class="eyebrow">New relative</p>
        <h1>Add Relative</h1>
        <p>Add someone and place them in your tree.</p>
    </div>
</section>

<form method="POST" class="form">
    <div class="form-group">
        <label for="first_name">First Name *</label>
        <input type="text" id="first_name" name="first_name" value="<%= data.first_name || '' %>" required>
    </div>

    <div class="form-group">
        <label for="last_name">Last Name *</label>
        <input type="text" id="last_name" name="last_name" value="<%= data.last_name || '' %>" required>
    </div>

    <div class="form-group">
        <label for="date_of_birth">Date of Birth</label>
        <input type="date" id="date_of_birth" name="date_of_birth" value="<%= data.date_of_birth || '' %>">
    </div>

    <div class="form-group">
        <label for="location_of_birth">Location of Birth</label>
        <input type="text" id="location_of_birth" name="location_of_birth"
            value="<%= data.location_of_birth || '' %>">
    </div>

    <div class="form-group">
        <label for="current_location">Current Location</label>
        <input type="text" id="current_location" name="current_location"
            value="<%= data.current_location || '' %>">
    </div>

    <div class="relationship-box">
        <h3>Relationship</h3>
        <p class="help-text">Tell the tree how this new person is connected to you.</p>

        <div class="form-group">
            <label for="relationship_type">This new person is my *</label>
            <select id="relationship_type" name="relationship_type" required>
                <option value="">-- Choose relationship --</option>
                <% relationshipTypes.forEach(type=> { %>
                    <option value="<%= type.value %>" <% if (data.relationship_type==type.value) { %>selected<% } %>>
                        <%= type.label %>
                    </option>
                <% }); %>
            </select>
        </div>

        <% if (selfMember) { %>
            <input type="hidden" name="related_member_id" value="<%= selfMember.id %>">
            <p class="help-text">Connected to <strong><%= selfMember.first_name %> <%= selfMember.last_name %></strong>.</p>
        <% } else { %>
            <p class="help-text">Your profile is created automatically when you sign up or log in.</p>
        <% } %>
    </div>

    <div class="form-actions">
        <button type="submit" class="btn btn-primary">Add Relative</button>
        <a href="/members" class="btn btn-secondary">Cancel</a>
    </div>
</form>
