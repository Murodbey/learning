<section class="hero">
    <p class="eyebrow">Welcome, <%= currentUser.name %></p>
    <h1>Your Family Tree</h1>
    <p>Organize and manage your family relationships in one private place.</p>
</section>

<div class="quick-actions">
    <div class="action-card">
        <h3>👥 Family Members</h3>
        <p>View and manage all family members</p>
        <a href="/members" class="btn btn-primary">View Members</a>
    </div>

    <div class="action-card">
        <h3>➕ Add New Member</h3>
        <p>Add a new family member to your tree</p>
        <a href="/members/add" class="btn btn-primary">Add Member</a>
    </div>

    <div class="action-card">
        <h3>🔗 Add Relationship</h3>
        <p>Connect family members with relationships</p>
        <a href="/relationships/add" class="btn btn-primary">Add Relationship</a>
    </div>
</div>
