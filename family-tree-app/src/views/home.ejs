<% const hasBranches = (branches) => branches && branches.length > 0; %>
<% const totalBranches = tree.grandparents.length + tree.parents.length + tree.siblings.length + tree.children.length + tree.auntUncles.length; %>

<% const renderPersonCard = (person, extraClass = '') => { %>
    <a href="/members/<%= person.id %>" class="tree-person <%= extraClass %>">
        <span class="person-name"><%= person.first_name %> <%= person.last_name %></span>
        <% if (person.relationshipLabel) { %>
            <span class="person-role"><%= person.relationshipLabel %></span>
        <% } %>
        <% if (person.current_location) { %>
            <span class="person-location"><%= person.current_location %></span>
        <% } %>
    </a>
<% }; %>

<% const renderBranch = (branch) => { %>
    <article class="branch-card">
        <div class="branch-top">
            <% renderPersonCard(branch.primary); %>

            <% if (branch.spouses && branch.spouses.length > 0) { %>
                <div class="branch-spouses">
                    <% branch.spouses.forEach(spouse=> { %>
                        <% renderPersonCard(spouse, 'is-compact'); %>
                    <% }); %>
                </div>
            <% } %>
        </div>

        <% if (branch.children && branch.children.length > 0) { %>
            <div class="branch-arrow"></div>
            <div class="branch-children">
                <% branch.children.forEach(child=> { %>
                    <% renderPersonCard(child, 'is-compact'); %>
                <% }); %>
            </div>
        <% } %>
    </article>
<% }; %>

<% const renderBranchSection = (title, branches) => { %>
    <% if (hasBranches(branches)) { %>
        <section class="tree-section">
            <div class="tree-section-head">
                <h3><%= title %></h3>
            </div>
            <div class="branch-grid">
                <% branches.forEach(branch=> { %>
                    <% renderBranch(branch); %>
                <% }); %>
            </div>
        </section>
    <% } %>
<% }; %>

<section class="tree-hero">
    <div>
        <p class="eyebrow">Welcome, <%= currentUser.name %></p>
        <h1>Your Family Tree</h1>
        <p>Partners stay beside the person they belong with, and children stay under their branch.</p>
    </div>
    <a href="/members/add" class="btn btn-primary">Add Relative</a>
</section>

<% if (selfMember) { %>
    <section class="family-tree">
        <% if (totalBranches === 0) { %>
            <section class="tree-start">
                <section class="tree-self">
                    <span class="person-role">Me</span>
                    <h2><%= selfMember.first_name %> <%= selfMember.last_name %></h2>
                    <% if (selfMember.current_location) { %>
                        <p class="tree-self-location"><%= selfMember.current_location %></p>
                    <% } %>
                    <a href="/members/<%= selfMember.id %>" class="tree-self-link">View profile</a>
                </section>
                <div>
                    <h2>Start with your first relative</h2>
                    <p>Add someone anywhere in the family, then keep branching outward from that person.</p>
                    <a href="/members/add" class="btn btn-primary">Add Relative</a>
                </div>
            </section>
        <% } else { %>
            <% renderBranchSection('Grandparents', tree.grandparents); %>
            <% renderBranchSection('Parents', tree.parents); %>

            <section class="tree-self-stage">
                <div class="tree-self-wrap">
                    <section class="tree-self">
                        <span class="person-role">Me</span>
                        <h2><%= selfMember.first_name %> <%= selfMember.last_name %></h2>
                        <% if (selfMember.current_location) { %>
                            <p class="tree-self-location"><%= selfMember.current_location %></p>
                        <% } %>
                        <a href="/members/<%= selfMember.id %>" class="tree-self-link">View profile</a>
                    </section>

                    <% if (tree.self && tree.self.spouses && tree.self.spouses.length > 0) { %>
                        <div class="tree-self-spouses">
                            <% tree.self.spouses.forEach(spouse=> { %>
                                <% renderPersonCard(spouse, 'is-compact'); %>
                            <% }); %>
                        </div>
                    <% } %>
                </div>
            </section>

            <% renderBranchSection('Siblings', tree.siblings); %>
            <% renderBranchSection('Children', tree.children); %>
            <% renderBranchSection('Aunts / Uncles', tree.auntUncles); %>
        <% } %>
    </section>
<% } else { %>
    <section class="empty-page">
        <h1>Your profile is getting ready</h1>
        <p>Refresh the page, then start adding relatives.</p>
        <a href="/members/add" class="btn btn-primary">Add Relative</a>
    </section>
<% } %>
