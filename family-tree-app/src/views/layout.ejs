<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Family Tree App</title>
    <link rel="stylesheet" href="/style.css?v=<%= Date.now() %>">
</head>

<body>
    <nav class="navbar">
        <div class="navbar-container">
            <a href="/" class="navbar-brand">🌳 Family Tree</a>
            <ul class="navbar-menu">
                <% if (currentUser) { %>
                    <li><a href="/">Home</a></li>
                    <li><a href="/members">All Members</a></li>
                    <li><a href="/members/add">Add Member</a></li>
                    <li><a href="/relationships/add">Add Relationship</a></li>
                    <li>
                        <form method="POST" action="/logout" class="nav-form">
                            <button type="submit">Logout</button>
                        </form>
                    </li>
                <% } else { %>
                    <li><a href="/login">Login</a></li>
                    <li><a href="/signup" class="nav-pill">Sign up</a></li>
                <% } %>
            </ul>
        </div>
    </nav>

    <div class="container">
        <% if (typeof message !=='undefined' && message) { %>
            <div class="alert alert-success">✓ <%= message %>
            </div>
            <% } %>
                <% if (typeof error !=='undefined' && error) { %>
                    <div class="alert alert-error">✗ <%= error %>
                    </div>
                    <% } %>

                        <%- body %>
    </div>

    <footer class="footer">
        <p>&copy; 2026 Family Tree App. All rights reserved.</p>
    </footer>
</body>

</html>
